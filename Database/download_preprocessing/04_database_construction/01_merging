library(data.table)
library(dplyr)
library(ggplot2)

# folder containing metadata-ready files
folder_path <- "/doctorai/chiarba/dataset/github"

# list all .tsv and .csv files in that folder
files <- list.files(
  folder_path,
  full.names = TRUE,
  pattern = "\\.(tsv|csv|txt)$"
)

# function to auto-read and assign to a variable based on filename
read_and_assign <- function(path) {
  fname <- tools::file_path_sans_ext(basename(path))
  df <- fread(path)
  
  # English comment: remove TCR immediately if v_call exists
  if ("v_call" %in% names(df)) {
    df <- df[!grepl("^TR", df$v_call), ]
  }
  
  assign(fname, df, envir = .GlobalEnv)
}

# read and create objects (one per file in the folder)
invisible(lapply(files, read_and_assign))

# dataset names derived *only* from the files in the github folder
datasets <- unique(vapply(
  files,
  function(path) tools::file_path_sans_ext(basename(path)),
  FUN.VALUE = character(1)
))


# convert AGE to character if present

invisible(lapply(
  datasets,
  function(nm) {
    if (exists(nm, envir = .GlobalEnv)) {
      df <- get(nm, envir = .GlobalEnv)
      if ("AGE" %in% names(df)) {
        df$AGE <- as.character(df$AGE)
        assign(nm, df, envir = .GlobalEnv)
      }
    }
  }
))

# convert SRA_id to character if present

invisible(lapply(
  datasets,
  function(nm) {
    if (exists(nm, envir = .GlobalEnv)) {
      df <- get(nm, envir = .GlobalEnv)
      if ("SRA_id" %in% names(df)) {
        df$SRA_id <- as.character(df$SRA_id)
        assign(nm, df, envir = .GlobalEnv)
      }
    }
  }
))

# bind rows into MS_DB

existing_dfs <- datasets[sapply(datasets, exists)]

MS_DB <- bind_rows(lapply(existing_dfs, get))

# final TR cleanup safety
MS_DB <- MS_DB[!grepl("^TR", MS_DB$v_call), ]

###Plotting overview

# --- Order 
MS_DB <- MS_DB %>%
  mutate(
    tissue = factor(
      tissue,
      levels = c(
        "CLN",           # Chronic: first; PPMS, SPMS: first
        "Choroid plexus",
        "blood",         # CIS, MS, PPMS, RRMS
        "Brain lesion",  # Chronic, PPMS, SPMS
        "Pia mater",
        "CSF"            # all CSF last where present
      )
    ),
    study = factor(
      study,
      levels = c(
        # MS / blood: Ruschill -> Greenfield -> Ryback -> Laurent -> Lomakin -> Zvyagin
        "Ruschill",
        "Greenfield",
        "Ryback",
        "Laurent",
        "Lomakin",
        "Zvyagin",
        # RRMS / blood: Perez_Salvidar -> Ramesh -> Palanichemy
        "Perez_Salvidar",
        "Ramesh",
        "Agrafiotis",   # appears in RRMS CSF
        "Palanichemy",
        # other studies
        "Stern"
      )
    )
  )

# --- Define palettes 

d3_11 <- c( '#e31a1c', '#ff7f00', '#fb9a99','#fdbf6f', "#fee08b", 
'#a6cee3','#1f78b4','#b2df8a','#80cdc1','#d8daeb','#8073ac'
)
current_palette <- d3_11

# Plotting overview
make_overview_plot <- function(palette) {
  ggplot(MS_DB, aes(x = tissue, fill = study)) +
    geom_bar(color = "black", position = "dodge") +
    labs(
      x = "tissue",
      y = "Number of Sequences",
      fill = "study"
    ) +
    theme_bw() +
    facet_wrap(~ disease_diagnosis, scales = "free_x", nrow = 1) +
    scale_y_log10() +
    # Add count labels in the middle of each bar
    geom_text(
      stat = "count",
      aes(y = after_stat(count) / 2, label = after_stat(count)),
      position = position_dodge(width = 0.9),
      angle = 90,
      vjust = 0.5,
      hjust = 0.5,
      size = 2,
      color = "black"
    ) +
    scale_fill_manual(values = palette, drop = FALSE) +
    theme(
      axis.text.x = element_text(angle = 45, vjust = 0.5, size = 7),
      strip.background = element_rect(fill = "white", color = "black")

    )
}

# Draw plot with chosen palette
p_overview <- make_overview_plot(current_palette)
print(p_overview)
